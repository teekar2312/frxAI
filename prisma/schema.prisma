// FinexFX AI Trading System - Prisma Schema
// Stack: Next.js 16 dashboard + (simulated) Python 3.14 / MT5 engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Trading Accounts (MT5 demo / live) =====
model Account {
  id            String   @id @default(cuid())
  name          String
  broker        String   @default("FINEX Indonesia")
  server        String
  login         String
  accountType   String   @default("demo") // demo | live
  currency      String   @default("USD")
  leverage      String   @default("1:100")
  balance       Float    @default(10000)
  equity        Float    @default(10000)
  margin        Float    @default(0)
  freeMargin    Float    @default(10000)
  marginLevel   Float    @default(0)
  connected     Boolean  @default(false)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trades        Trade[]
  orders        Order[]
}

// ===== Trades / Positions =====
model Trade {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol        String   // EURUSD | USDJPY | GBPUSD | XAUUSD
  side          String   // buy | sell
  lotSize       Float
  openPrice     Float
  closePrice    Float?
  stopLoss      Float?
  takeProfit    Float?
  trailingStop  Boolean  @default(false)
  trailingPips  Float    @default(0)
  status        String   @default("open") // open | closed
  pnl           Float    @default(0)
  pips          Float    @default(0)
  commission    Float    @default(0)
  swap          Float    @default(0)
  strategy      String   @default("scalping-m5")
  timeframe     String   @default("M5")
  source        String   @default("manual") // manual | auto | ai
  comment       String?
  // MT5 bridge integration: ticket returned by the bridge (null = local-only trade).
  // When non-null, the trade exists on the real (or mock) MT5 bridge and can be
  // reconciled / closed via the bridge's position ticket.
  mt5Ticket     Int?
  mt5Server     String?
  openTime      DateTime @default(now())
  closeTime     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountId])
  @@index([symbol])
  @@index([status])
  @@index([mt5Ticket])
  @@index([source])
  @@index([openTime])
  @@index([accountId, status])
}

// ===== Pending Orders =====
model Order {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol        String
  side          String   // buy | sell
  orderType     String   // limit | stop
  lotSize       Float
  price         Float
  stopLoss      Float?
  takeProfit    Float?
  status        String   @default("pending") // pending | triggered | cancelled
  openTime      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountId])
}

// ===== Indicator Pool (scalping preset) =====
model Indicator {
  id            String   @id @default(cuid())
  name          String   @unique
  category      String   // trend | oscillator | volume | volatility | channel | regression
  description   String
  defaultParams String   // JSON string of params
  scalpingPreset String? // JSON string of scalping-optimized params
  enabled       Boolean  @default(true)
  autoManaged   Boolean  @default(false) // AI can toggle
  weight        Float    @default(1) // AI-assigned weight 0..1
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ===== News Items (Finnhub / MARKETAUX) =====
model NewsItem {
  id            String   @id @default(cuid())
  source        String   // finnhub | marketaux | breaking
  title         String
  summary       String
  url           String?
  category      String   // central_bank | nfp | cpi | ppi | gdp | unemployment | retail | pmi | geopolitical | fiscal | commodity | sentiment | breaking
  impact        String   @default("medium") // low | medium | high
  sentiment     String   @default("neutral") // bullish | bearish | neutral
  symbols       String   @default("") // comma separated EURUSD,USDJPY,...
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([category])
  @@index([impact])
  @@index([publishedAt])
}

// ===== Price Alerts =====
model Alert {
  id            String   @id @default(cuid())
  symbol        String
  condition     String   // above | below | cross_up | cross_down
  price         Float
  active        Boolean  @default(true)
  triggered     Boolean  @default(false)
  triggeredAt   DateTime?
  notifyEmail   Boolean  @default(true)
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([symbol])
  @@index([active])
}

// ===== System Logs / Error Logs =====
model Log {
  id            String   @id @default(cuid())
  level         String   // info | warn | error | debug
  source        String   @default("system") // mt5 | ai | risk | api | ws | backtest
  message       String
  stack         String?
  context       String?  // JSON
  createdAt     DateTime @default(now())

  @@index([source])
  @@index([level, createdAt])
}

// ===== Backtest Results =====
model Backtest {
  id            String   @id @default(cuid())
  name          String
  symbol        String
  timeframe     String   @default("M5")
  strategy      String
  periodFrom    DateTime
  periodTo      DateTime
  initialCapital Float
  finalCapital  Float
  totalTrades   Int
  winTrades     Int
  lossTrades    Int
  winRate       Float
  profitFactor  Float
  maxDrawdown   Float
  sharpeRatio   Float
  netProfit     Float
  equityCurve   String   // JSON array
  tradesJson    String   // JSON array of trade points
  status        String   @default("completed") // running | completed | failed
  createdAt     DateTime @default(now())

  @@index([symbol])
}

// ===== AI Signals (ML self-learning log) =====
model AiSignal {
  id            String   @id @default(cuid())
  symbol        String
  direction     String   // long | short | neutral
  confidence    Float    // 0..100
  timeframe     String   @default("M5")
  reasoning     String
  selectedIndicators String // JSON array
  factors       String   // JSON: central_bank, nfp, cpi, etc scores
  action        String   @default("wait") // buy | sell | wait
  modelVersion  String   @default("fx-scalper-v1")
  accuracy      Float    @default(0) // rolling accuracy %
  priceAtSignal Float?   // price when signal was generated (for outcome eval)
  createdAt     DateTime @default(now())

  outcome       AiSignalOutcome?

  @@index([symbol])
  @@index([createdAt])
  @@index([action])
}

// ===== AI Signal Outcomes (r11-AI: real accuracy tracking) =====
// Evaluates whether a signal was correct by comparing price movement
// after the signal's hold period to the predicted direction.
model AiSignalOutcome {
  id            String   @id @default(cuid())
  signalId      String   @unique
  signal        AiSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  symbol        String
  direction     String   // long | short | neutral
  action        String   // buy | sell | wait
  confidence    Float    // confidence at signal time
  priceAtSignal Float    // price when signal was generated
  priceAtEval   Float    // price at evaluation time
  priceChange   Float    // absolute price change
  priceChangePct Float   // percentage price change
  pipsMoved     Float    // pips moved in predicted direction (negative = against)
  correct       Boolean? // null = not yet evaluated, true/false = evaluated
  evaluatedAt   DateTime?

  @@index([symbol])
  @@index([correct])
  @@index([evaluatedAt])
}

// ===== Risk Settings (key-value global) =====
model RiskSetting {
  id            String   @id @default(cuid())
  key           String   @unique
  value         String
  updatedAt     DateTime @updatedAt
}

// ===== Email Notifications =====
model Notification {
  id            String   @id @default(cuid())
  type          String   // trade_open | trade_close | alert | risk | system | news
  subject       String
  body          String
  recipient     String
  sent          Boolean  @default(false)
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([recipient])
}

// ===== System Config (broker, API keys, email) =====
model SystemConfig {
  id            String   @id @default(cuid())
  key           String   @unique
  value         String
  updatedAt     DateTime @updatedAt
}

// ===== Users (authentication & authorization) =====
// r10-auth: NextAuth credentials provider. Passwords are bcrypt-hashed.
// Roles: admin (full access), trader (can open/close trades), viewer (read-only).
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String   // bcrypt hash
  role          String   @default("trader") // admin | trader | viewer
  active        Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      UserSession[]

  @@index([email])
  @@index([role])
}

// ===== User Sessions (optional — NextAuth uses JWT by default, but we log sessions for audit) =====
model UserSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken  String   @unique
  expiresAt     DateTime
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ===== Economic Calendar Events =====
// Tracks high-impact macro events: NFP, CPI, PPI, GDP, unemployment,
// retail sales, PMI, central bank rate decisions, press conferences.
model EconomicEvent {
  id            String   @id @default(cuid())
  title         String
  country       String   // US | EU | GB | JP
  currency      String   // USD | EUR | GBP | JPY
  category      String   // interest_rate | nfp | cpi | ppi | gdp | unemployment | retail | pmi | speech | other
  impact        String   // low | medium | high
  eventTime     DateTime // scheduled time (UTC)
  actual        String?
  forecast      String?
  previous      String?
  surprise      String?  // computed surprise description
  symbols       String   @default("") // comma separated affected pairs
  status        String   @default("upcoming") // upcoming | released | cancelled
  source        String   @default("marketaux")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([eventTime])
  @@index([impact])
  @@index([category])
  @@index([country])
}
