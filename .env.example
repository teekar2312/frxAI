# FinexFX AI Trading System — Environment Variables
# Copy this file to `.env` and adjust values for your environment.

# Prisma database URL (SQLite by default — absolute path recommended)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# (Optional) MT5 bridge credentials — fill when integrating live MT5
# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=

# (Optional) News API keys — for real news feed (currently uses LLM-synthesized news)
# NEWSAPI_KEY=
# MARKETAUX_KEY=
# FINNHUB_KEY=

# (Optional) Webhook URLs — configure via Settings → Webhook in the dashboard instead
# DISCORD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SLACK_WEBHOOK_URL=
