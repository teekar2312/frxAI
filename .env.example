# FinexFX AI Trading System — Environment Variables
# Copy this file to `.env` and adjust values for your environment.
# Variables marked (Required) will cause startup failure in production if missing.

# ─── Database ───────────────────────────────────────────────────────────────
# Prisma database URL (SQLite by default — absolute path recommended)
DATABASE_URL=file:../db/frxai.db

# ─── Authentication (Required in production) ───────────────────────────────
# NextAuth JWT secret — MUST be ≥32 characters in production
# Generate one with: openssl rand -base64 32
# NEXTAUTH_SECRET=

# NextAuth callback URL — set to your public URL in production
# NEXTAUTH_URL=http://localhost:3000

# ─── Service-to-Service Auth ───────────────────────────────────────────────
# Key for background service endpoints (SL/TP monitor, reconcile, evaluate, backup)
# MUST be changed from default in production
# SERVICE_API_KEY=change-me-in-production

# ─── MT5 Bridge ──────────────────────────────────────────────────────────────
# API key for MT5 bridge communication (must match bridge's BRIDGE_API_KEY)
# BRIDGE_API_KEY=change-me-in-production

# Bridge adapter: "mock" (dev/synthetic) or "real-python" (production with MT5)
# MT5_ADAPTER=mock

# URL for real Python MT5 bridge (only used when MT5_ADAPTER=real-python)
# MT5_PYTHON_BRIDGE_URL=http://192.168.1.50:5050

# MT5 credentials — can also be set per-account via the dashboard
# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=

# ─── News API Keys (Optional) ──────────────────────────────────────────────
# If not set, the system uses LLM-synthesized news via z-ai-web-dev-sdk
# NEWSAPI_KEY=
# MARKETAUX_KEY=
# FINNHUB_KEY=

# ─── Webhook Notifications (Optional) ──────────────────────────────────────
# Can also be configured via Settings → Webhooks in the dashboard
# DISCORD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SLACK_WEBHOOK_URL=